{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:allow-open-url",
    "opener:allow-default-urls",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPLOCALDATA/themes" },
        { "path": "$APPLOCALDATA/themes/*" },
        { "path": "$APPLOCALDATA/themes/**/*" }
      ]
    },
    "dialog:default",
    "shell:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-remove",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPLOCALDATA/backgrounds",
        "$APPLOCALDATA/backgrounds/*",
        "$APPLOCALDATA/backgrounds/**/*",
        "$APPLOCALDATA/themes",
        "$APPLOCALDATA/themes/*",
        "$APPLOCALDATA/themes/**/*"
      ]
    },
    "notification:default",
    "updater:default",
    "process:default"
  ]
}
