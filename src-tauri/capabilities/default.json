{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "shell:default",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPLOCALDATA/backgrounds/**/*",
        "$APPLOCALDATA/themes/**/*"
      ]
    },
    "notification:default",
    "updater:default",
    "process:default"
  ]
}
